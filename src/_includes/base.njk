<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="robots" content="noindex, nofollow">
  {% set pageTitle %}{% if title %}{{ title }}{% elif work %}{{ work | workName }}{% else %}{{ site.name }}{% endif %}{% endset %}
  {% set cardTitle %}{% if work %}ネタバレ注意 | {{ work | workName }}{% else %}{{ pageTitle }}{% endif %}{% endset %}
  {% set cardDescription = "食べ食べのネタバレツイート置き場" %}
  {% set cardImage = "" %}
  {% if work %}
    {% set cardImage = work | workCardImage %}
  {% endif %}
  <title>{% if pageTitle != site.name %}{{ pageTitle }} | {% endif %}{{ site.name }}</title>
  <meta property="og:title" content="{{ cardTitle | trim }}">
  <meta property="og:description" content="{{ cardDescription }}">
  <meta property="og:type" content="{% if work %}article{% else %}website{% endif %}">
  <meta property="og:url" content="{{ page.url | absoluteUrl(site) }}">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{{ cardTitle | trim }}">
  <meta name="twitter:description" content="{{ cardDescription }}">
  {% if cardImage %}
    <meta property="og:image" content="{{ cardImage | absoluteUrl(site) }}">
    <meta name="twitter:image" content="{{ cardImage | absoluteUrl(site) }}">
  {% endif %}
  <link rel="stylesheet" href="{{ '/assets/style.css' | url }}?v={{ site.assetVersion }}">
</head>
<body>
  <main class="wrap">
    {% if showHomeLink != false %}
      <p class="home-link"><a href="{{ '/' | url }}">← 作品一覧へ</a></p>
    {% endif %}
    {{ content | safe }}
  </main>

  <div id="lightbox" class="lightbox" hidden>
    <button id="lightbox-close" class="lightbox-close" aria-label="閉じる">×</button>
    <img id="lightbox-image" class="lightbox-image" src="" alt="">
  </div>

  <script>
    document.addEventListener("click", function (e) {
      const img = e.target.closest(".post img");
      if (!img) return;

      const lightbox = document.getElementById("lightbox");
      const lightboxImage = document.getElementById("lightbox-image");

      lightboxImage.src = img.src;
      lightboxImage.alt = img.alt || "";
      lightbox.hidden = false;
      document.body.style.overflow = "hidden";
    });

    document.getElementById("lightbox-close").addEventListener("click", closeLightbox);

    document.getElementById("lightbox").addEventListener("click", function (e) {
      if (e.target.id === "lightbox") closeLightbox();
    });

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") closeLightbox();
    });

    const spoilerGateStorageKey = "spoiler-log-gate-open";

    document.querySelectorAll("[data-spoiler-gate]").forEach(function (gate) {
      try {
        if (sessionStorage.getItem(spoilerGateStorageKey) === "true") {
          gate.classList.add("is-open");
        }
      } catch (e) {}

      const button = gate.querySelector(".spoiler-open-button");
      if (!button) return;

      button.addEventListener("click", function () {
        gate.classList.add("is-open");

        try {
          sessionStorage.setItem(spoilerGateStorageKey, "true");
        } catch (e) {}
      });
    });

    const hashTarget = location.hash ? document.getElementById(decodeURIComponent(location.hash.slice(1))) : null;

    if (hashTarget) {
      const scrollToHashTarget = function () {
        hashTarget.scrollIntoView({ block: "start" });
      };

      requestAnimationFrame(scrollToHashTarget);
      [120, 400, 900, 1600].forEach(function (delay) {
        window.setTimeout(scrollToHashTarget, delay);
      });
      window.addEventListener("load", scrollToHashTarget, { once: true });

      document.querySelectorAll("img").forEach(function (img) {
        if (!img.complete) {
          img.addEventListener("load", scrollToHashTarget, { once: true });
          img.addEventListener("error", scrollToHashTarget, { once: true });
        }
      });
    }

    function closeLightbox() {
      const lightbox = document.getElementById("lightbox");
      const lightboxImage = document.getElementById("lightbox-image");

      lightbox.hidden = true;
      lightboxImage.src = "";
      document.body.style.overflow = "";
    }
  </script>
</body>
</html>
