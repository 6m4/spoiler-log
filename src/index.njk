---
layout: base.njk
title: 作品一覧
showHomeLink: false
---

{% if site.indexImage %}
  <p class="index-image">
    <img src="{{ site.indexImage | url }}" alt="">
  </p>
{% endif %}

<h1 class="index-title">食べ食べのネタバレツイート置き場</h1>
<p class="spoiler-note">⚠ リンク先ネタバレ注意 ⚠</p>
{% if site.indexDescription %}
  <p class="index-description">{{ site.indexDescription }}</p>
{% endif %}

<ul class="work-list">
  {% for work in collections.workSummaries %}
    <li>
      <a href="{{ ('/works/' ~ work.slug ~ '/') | url }}">
        {% if work.cardImage %}
          <span class="work-thumb">
            <img src="{{ work.cardImage | url }}" alt="">
          </span>
        {% endif %}
        <span class="work-main">
          <strong>{{ work.name }}</strong>
          <span class="work-meta">
            {% if work.count > 0 %}
              {{ work.count }}件 ・ 最終更新
              <time datetime="{{ work.latestPost.date.toISOString() }}">
                {{ work.latestPost.date.toLocaleDateString("ja-JP", {
                  timeZone: "Asia/Tokyo"
                }) }}
              </time>
            {% else %}
              まだ投稿なし
            {% endif %}
          </span>
        </span>
      </a>
    </li>
  {% endfor %}
</ul>
