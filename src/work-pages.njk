---
layout: base.njk
pagination:
  data: collections.workPageDefs
  size: 1
  alias: pageDef
permalink: "{{ pageDef.permalink }}"
---

{% set allPosts = collections["work_" ~ pageDef.slug] %}
{% set posts = allPosts.slice(pageDef.start, pageDef.end) %}

{% if pageDef.pageNumber > 1 %}
  {% set title = pageDef.name ~ " - " ~ pageDef.pageNumber ~ "ページ目" %}
{% else %}
  {% set title = pageDef.name %}
{% endif %}

{% macro pager(pageDef, position) %}
  <nav class="pager{% if position %} pager-{{ position }}{% endif %}">
    {% if pageDef.pageNumber > 1 %}
      {% if pageDef.pageNumber == 2 %}
        <a href="{{ ('/works/' ~ pageDef.slug ~ '/') | url }}">← 前のページ</a>
      {% else %}
        <a href="{{ ('/works/' ~ pageDef.slug ~ '/page/' ~ (pageDef.pageNumber - 1) ~ '/') | url }}">← 前のページ</a>
      {% endif %}
    {% else %}
      <span class="hidden">← 前のページ</span>
    {% endif %}

    <span class="pager-current">{{ pageDef.pageNumber }} / {{ pageDef.totalPages }}</span>

    {% if pageDef.pageNumber < pageDef.totalPages %}
      <a href="{{ ('/works/' ~ pageDef.slug ~ '/page/' ~ (pageDef.pageNumber + 1) ~ '/') | url }}">次のページ →</a>
    {% else %}
      <span class="hidden">次のページ →</span>
    {% endif %}
  </nav>
{% endmacro %}

<p class="page-kicker">食べ食べのネタバレツイート置き場</p>
<h1>{{ pageDef.name }}</h1>
<p class="spoiler-note">⚠ ネタバレ注意 ⚠</p>

{% if pageDef.totalPages > 1 %}
  {{ pager(pageDef, "top") }}
{% endif %}

{% if posts.length > 0 %}
  {% for post in posts %}
    <article class="post" id="{{ post | postAnchor }}">
      {{ post.templateContent | safe }}
      <a class="post-time-link" href="{{ post | postUrl | url }}">
        <time datetime="{{ post.date.toISOString() }}">
          {{ post.date.toLocaleString("ja-JP", {
            timeZone: "Asia/Tokyo",
            year: "numeric",
            month: "numeric",
            day: "numeric",
            hour: "2-digit",
            minute: "2-digit",
            hourCycle: "h23"
          }) }}
        </time>
      </a>
    </article>
  {% endfor %}
{% else %}
  <p>まだ投稿はありません。</p>
{% endif %}

<nav class="pager">
  {% if pageDef.pageNumber > 1 %}
    {% if pageDef.pageNumber == 2 %}
      <a href="{{ ('/works/' ~ pageDef.slug ~ '/') | url }}">← 前のページ</a>
    {% else %}
      <a href="{{ ('/works/' ~ pageDef.slug ~ '/page/' ~ (pageDef.pageNumber - 1) ~ '/') | url }}">← 前のページ</a>
    {% endif %}
  {% else %}
    <span class="hidden">← 前のページ</span>
  {% endif %}

  <span class="pager-current">{{ pageDef.pageNumber }} / {{ pageDef.totalPages }}</span>

  {% if pageDef.pageNumber < pageDef.totalPages %}
    <a href="{{ ('/works/' ~ pageDef.slug ~ '/page/' ~ (pageDef.pageNumber + 1) ~ '/') | url }}">次のページ →</a>
  {% else %}
    <span class="hidden">次のページ →</span>
  {% endif %}
</nav>
